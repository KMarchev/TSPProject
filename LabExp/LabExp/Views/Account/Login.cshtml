@{
    ViewData["Title"] = "Login";
    Layout = "";
}
@model LabExp.Models.AccountModels.LoginModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <style>
            body {
                font-family: Arial, sans-serif;
                background-color: #f4f4f4;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 98vh;
            }

            .login-container {
                background: white;
                padding: 30px;
                border-radius: 10px;
                width: 350px;
                box-shadow: 0 0 15px rgba(0,0,0,0.1);
            }

            .login-container h2 {
                text-align: center;
                margin-bottom: 25px;
            }

            .form-group {
                margin-bottom: 15px;
            }

            .form-group span{
                color:red;
            }

            .form-control {
                width: 100%;
                padding: 10px;
                border: 1px solid #ccc;
                border-radius: 5px;
                box-sizing: border-box;
            }

            .btn-login {
                width: 100%;
                padding: 10px;
                background-color: #0d6efd;
                color: white;
                border: none;
                border-radius: 5px;
                cursor: pointer;
            }

            .btn-login:hover {
                background-color: #0b5ed7;
            }
    </style>
</head>
<body>

    <div class="login-container">
        <h2>Login</h2>

        <form method="post" asp-controller="Account" asp-action="Login">
            <div class="form-group">
                <input type="email"
                       name="Email"
                       class="form-control"
                       placeholder="Email"
                       required
                       asp-for="Email"/>

                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="password"
                       name="Password"
                       class="form-control"
                       placeholder="Password"
                       required 
                       asp-for="Password"/>

                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">
                Sign In
            </button>
        </form>
    </div>

</body>
</html>